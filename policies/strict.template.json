{
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(vigil-install-review:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(git clean:*)",
      "Bash(git restore:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash pop:*)",
      "Bash(git checkout -- *)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(npx:*)",
      "Bash(npm publish:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(sftp:*)",
      "Bash(rsync:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(socat:*)",
      "Bash(telnet:*)",
      "Bash(ftp:*)",
      "Read({{HOME}}/.ssh/**)",
      "Read({{HOME}}/.aws/**)",
      "Read({{HOME}}/.netrc)",
      "Read({{HOME}}/.kube/**)",
      "Read({{HOME}}/.docker/config.json)",
      "Read({{HOME}}/.config/gh/**)",
      "Read({{HOME}}/.config/doctl/**)"
    ]
  }
}
