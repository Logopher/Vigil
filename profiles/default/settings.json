{
  "sandbox": {
    "enabled": true,
    "mode": "auto-allow",
    "allowUnsandboxedCommands": false,
    "allowedDomains": []
  },
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(git clean:*)",
      "Bash(git restore:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash pop:*)",
      "Bash(git checkout -- *)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(npx:*)",
      "Bash(npm publish:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/grault/code/claude-config/hooks/prune-worktrees.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/grault/code/claude-config/hooks/prune-worktrees.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/grault/code/claude-config/hooks/log-tool-use.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/grault/code/claude-config/hooks/log-tool-result.sh"
          }
        ]
      }
    ]
  }
}
