{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit -m*)",
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(npm run test*)",
      "Bash(npm run dev*)"
    ],
    "deny": [
      "Read(.git/**)",
      "Write(.git/**)",
      "Edit(.git/**)",
      "Write(.claude/**)",
      "Edit(.claude/**)"
    ],
    "ask": [
      "Bash(git commit --amend*)",
      "Bash(git stash*)",
      "WebFetch(*)"
    ]
  }
}